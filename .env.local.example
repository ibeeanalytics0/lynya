# ─────────────────────────────────────────────────────────────
# Lynya Organics — Environment Variables
# ─────────────────────────────────────────────────────────────
# NEVER commit this file to Git. It is in .gitignore.
#
# For local development:  copy this to .env.local and fill in values
# For production (Vercel): add these in Vercel Dashboard → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────

# Get from: https://dashboard.stripe.com/apikeys
# Use sk_test_... for testing, sk_live_... when Stripe approves your account
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_KEY

# Your deployed Vercel URL (no trailing slash)
YOUR_DOMAIN=https://lynya02.vercel.app
